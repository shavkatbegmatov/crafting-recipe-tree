# ============================================================================
# Backend / Database env (used by docker-compose.yml and Coolify backend app)
# ============================================================================

# Database
DB_NAME=crafttree
DB_USERNAME=postgres
DB_PASSWORD=changeme

# JWT — base64-encoded secret (min 256 bits)
JWT_SECRET=changeme_base64_encoded_secret_key

# CORS — comma-separated list of frontend origins allowed to hit the API.
# In production set this to your frontend's public URL (no trailing slash).
# Example: https://crafttree.example.com
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================================================
# Frontend build-time env (only used by GitHub Actions when building the image)
# Set this as a GitHub Actions secret: VITE_API_BASE_URL
# ============================================================================
# Example: https://api.crafttree.example.com  (no trailing slash, no /api suffix)
# VITE_API_BASE_URL=
