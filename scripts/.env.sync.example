# =============================================================================
# Upload sync — pulls missing image files from production into backend/uploads/.
#
# Copy this file to `.env.sync` (which is git-ignored) and fill in the values.
# The script reads ONLY this file (or process.env) — never .env.local.
# =============================================================================

# Production API root, no trailing slash.
PROD_API_URL=https://api.erz-online.uz

# Admin credentials used to fetch the upload manifest.
# Use a real admin account from the production DB.
PROD_ADMIN_USERNAME=admin
PROD_ADMIN_PASSWORD=

# Where the synced files are written (relative to repo root).
# Default matches `app.uploads.path: uploads` resolved against the backend cwd.
LOCAL_UPLOADS_DIR=backend/uploads

# How many files to download in parallel. Be polite to the server.
SYNC_CONCURRENCY=4
