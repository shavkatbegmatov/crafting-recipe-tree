# =============================================================================
# Upload sync — pulls image_url mapping AND missing image files from production
# into your local backend (DB + filesystem).
#
# Copy this file to `.env.sync` (which is git-ignored) and fill it in.
# The script reads ONLY this file (or process.env) — never .env.local.
# =============================================================================

# ---------- Production (source of truth) -------------------------------------
# Production API root, no trailing slash.
PROD_API_URL=https://api.erz-online.uz

# Admin credentials used to fetch the upload manifest.
PROD_ADMIN_USERNAME=admin
PROD_ADMIN_PASSWORD=

# ---------- Local backend (sync target) --------------------------------------
# Where the local backend listens. Defaults match the dev profile.
LOCAL_API_URL=http://localhost:8089

# Local admin account — the Flyway V7 seed creates `admin / admin123`.
# Override if you have changed it locally.
LOCAL_ADMIN_USERNAME=admin
LOCAL_ADMIN_PASSWORD=admin123

# Where the synced files are written (relative to repo root).
LOCAL_UPLOADS_DIR=backend/uploads

# ---------- Tuning -----------------------------------------------------------
# How many files to download in parallel. Be polite to the server.
SYNC_CONCURRENCY=4

# Set to 1 to skip the DB image_url mapping step and only sync files.
# Useful if your local backend isn't running.
# SKIP_DB_SYNC=0
